@model List<ResultCarDto>
@{
    ViewData["Title"] = "CarList";
    Layout = "~/Views/Shared/_ClientLayout.cshtml";

    var cars = Model ?? new List<ResultCarDto>();
    var minPrice = cars.Any() ? (int)Math.Floor(cars.Min(x => x.DailyPrice)) : 0;
    var maxPrice = cars.Any() ? (int)Math.Ceiling(cars.Max(x => x.DailyPrice)) : 0;
    var categories = cars
        .Select(x => x.Category?.CategoryName)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
    var brands = cars
        .Select(x => x.Brand)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
    var fuelTypes = cars
        .Select(x => x.FuelType)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
    var transmissionTypes = cars
        .Select(x => x.TransmissionType)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)
        .ToList();
}

<style>
    .car-listing-hero {
        position: relative;
        overflow: hidden;
    }

    .car-listing-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(10, 15, 24, 0.82) 0%, rgba(10, 15, 24, 0.58) 38%, rgba(10, 15, 24, 0.22) 100%);
    }

    .car-listing-hero .banner-content {
        position: relative;
        z-index: 1;
        padding: 34px 0;
    }

    .car-listing-hero .banner-content h1 {
        color: #fff;
        margin-bottom: 0;
    }

    .car-filter-empty {
        display: none;
        padding: 18px 22px;
        border: 1px solid #e6e6e6;
        border-radius: 16px;
        background: #fff;
        color: #6b7280;
        font-size: 15px;
    }

    .car-pagination-wrap {
        display: flex;
        justify-content: center;
        margin-top: 32px;
    }

    .car-pagination {
        display: none;
        align-items: center;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .car-pagination.is-visible {
        display: flex;
    }

    .car-pagination-btn,
    .car-pagination-number {
        min-width: 44px;
        height: 44px;
        padding: 0 16px;
        border: 1px solid #d9dfef;
        border-radius: 999px;
        background: #fff;
        color: #0f172a;
        font-size: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all .2s ease;
        cursor: pointer;
    }

    .car-pagination-btn:hover,
    .car-pagination-number:hover {
        border-color: #3f7df6;
        color: #3f7df6;
        box-shadow: 0 10px 24px rgba(63, 125, 246, 0.14);
    }

    .car-pagination-number.is-active {
        background: #3f7df6;
        border-color: #3f7df6;
        color: #fff;
        box-shadow: 0 14px 30px rgba(63, 125, 246, 0.24);
    }

    .car-pagination-btn[disabled] {
        opacity: .45;
        cursor: not-allowed;
        box-shadow: none;
    }
</style>

<section class="breadcrumb-section car-listing-hero" style="background-image: url('@Url.Content("~/carola pack/carola/assets/images/background/car-listing-collage-banner-v2.png")');">
    <div class="container">
        <div class="banner-content">
            <h1>Araç Listesi</h1>
        </div>
    </div>
</section>

<section class="car-listing-section pt_120 pb_90">
    <div class="container">
        <div class="row">
            <div class="col-xl-4 col-lg-4 col-md-12 col-sm-12">
                <div class="product-sidebar mr_30">
                    <div class="sidebar-search-widget">
                        <h3 class="sidebar-widget-title">Ara</h3>
                        <div class="sidebar-search-box">
                            <input type="text" id="carSearchInput" placeholder="Marka veya model ara...">
                            <button type="button" id="carSearchButton"><i class="icon-18"></i></button>
                        </div>
                    </div>
                    <div class="sidebar-select-car-widget">
                        <h3 class="sidebar-widget-title">Araç Seç</h3>
                        <div class="filter-box">
                            <div class="custom-select">
                                <select id="categoryFilter">
                                    <option value="">Kategori Seçin</option>
                                    @foreach (var category in categories)
                                    {
                                        <option value="@category!.Trim().ToLowerInvariant()">@category</option>
                                    }
                                </select>
                            </div>
                            <div class="custom-select">
                                <select id="brandFilter">
                                    <option value="">Marka Seçin</option>
                                    @foreach (var brand in brands)
                                    {
                                        <option value="@brand!.Trim().ToLowerInvariant()">@brand</option>
                                    }
                                </select>
                            </div>
                            <div class="custom-select">
                                <select id="fuelFilter">
                                    <option value="">Yakıt Türü Seçin</option>
                                    @foreach (var fuelType in fuelTypes)
                                    {
                                        <option value="@fuelType!.Trim().ToLowerInvariant()">@fuelType</option>
                                    }
                                </select>
                            </div>
                            <div class="custom-select">
                                <select id="transmissionFilter">
                                    <option value="">Vites Türü Seçin</option>
                                    @foreach (var transmissionType in transmissionTypes)
                                    {
                                        <option value="@transmissionType!.Trim().ToLowerInvariant()">@transmissionType</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="sidebar-filter-widget">
                        <h3 class="sidebar-widget-title">Filter by Price</h3>
                        <div class="price-range-slider">
                            <div id="slider-range" class="range-bar"></div>
                            <p class="range-value">
                                <span>Fiyat:</span>
                                <input type="text" id="amount" readonly>
                            </p>
                            <div class="btn-box">
                                <button type="button" class="clear-btn" id="clearPriceFilterBtn">Temizle</button>
                                <button type="button" class="filter-btn btn-style-four" id="applyPriceFilterBtn">Uygula</button>
                            </div>
                        </div>
                    </div>
                    <div class="sidebar-capacity-widget">
                        <h3 class="sidebar-widget-title">Kapasite</h3>
                        <ul class="capacity-list">
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox1" data-min="0" data-max="1">
                                    <label for="checkbox1">0-1 Kişi</label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox2" data-min="1" data-max="2">
                                    <label for="checkbox2">1-2 Kişi</label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox3" data-min="2" data-max="3">
                                    <label for="checkbox3">2-3 Kişi</label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox4" data-min="3" data-max="4">
                                    <label for="checkbox4">3-4 Kişi</label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox5" data-min="4" data-max="5">
                                    <label for="checkbox5">4-5 Kişi</label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox6" data-min="5" data-max="6">
                                    <label for="checkbox6">5-6 Kişi</label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check capacity-filter" type="checkbox" id="checkbox7" data-min="7" data-max="999">
                                    <label for="checkbox7">7+ Kişi</label>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <div class="sidebar-reviews-widget">
                        <h3 class="sidebar-widget-title">Değerlendirme</h3>
                        <ul class="reviews-list">
                            <li>
                                <div class="check-box">
                                    <input class="check" type="checkbox" id="checkbox8">
                                    <label for="checkbox8">
                                        <ul class="rating-star">
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                        </ul>
                                    </label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check" type="checkbox" id="checkbox9">
                                    <label for="checkbox9">
                                        <ul class="rating-star">
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                        </ul>
                                    </label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check" type="checkbox" id="checkbox10">
                                    <label for="checkbox10">
                                        <ul class="rating-star">
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                        </ul>
                                    </label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check" type="checkbox" id="checkbox11">
                                    <label for="checkbox11">
                                        <ul class="rating-star">
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                        </ul>
                                    </label>
                                </div>
                            </li>
                            <li>
                                <div class="check-box">
                                    <input class="check" type="checkbox" id="checkbox12">
                                    <label for="checkbox12">
                                        <ul class="rating-star">
                                            <li class="rated-star"><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                            <li><i class="fa-solid fa-star"></i></li>
                                        </ul>
                                    </label>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-xl-8 col-lg-8 col-md-12 col-sm-12">
                <div class="row">
                    @foreach (var item in cars)
                    {
                        <div class="col-xl-6 col-lg-6 col-md-6 col-sm-12 car-price-item"
                             data-price="@item.DailyPrice"
                             data-brand="@item.Brand?.Trim().ToLowerInvariant()"
                             data-category="@item.Category?.CategoryName?.Trim().ToLowerInvariant()"
                             data-fuel="@item.FuelType?.Trim().ToLowerInvariant()"
                             data-transmission="@item.TransmissionType?.Trim().ToLowerInvariant()"
                             data-seat="@item.SeatCount"
                             data-search="@($"{item.Brand} {item.Model} {item.Category?.CategoryName} {item.FuelType} {item.TransmissionType}".Trim().ToLowerInvariant())">
                            <div class="single-popular-car-block">
                                <div class="single-popular-car-image">
                                    <img src="@item.ImageUrl" alt="@($"{item.Brand} {item.Model}")">
                                    <div class="single-popular-car-rent-per-day"><span>@item.DailyPrice ₺</span>/ Gün</div>
                                </div>
                                <div class="single-popular-car-content">
                                    <div class="single-popular-car-rating"><i class="icon-9"></i>4.8</div>
                                    <h5 class="single-popular-car-title">@item.Brand @item.Model</h5>
                                    <p class="single-popular-car-text">
                                        @item.ModelYear model, @item.FuelType yakıtlı, @item.TransmissionType vitesli konforlu araç seçeneği.
                                    </p>
                                    <div class="border-divider"></div>
                                    <ul class="single-popular-car-info">
                                        <li><i class="icon-6"></i>Kategori: @(item.Category?.CategoryName ?? "-")</li>
                                        <li><i class="icon-7"></i>Bagaj: @item.LuggageCapacity Adet</li>
                                        <li><i class="icon-8"></i>Yolcu: @item.SeatCount</li>
                                    </ul>
                                    <div class="single-popular-car-book-btn">
                                        <a href="@Url.Action("BookingClient", "Booking", new { area = "", carId = item.CarId })" class="btn-style-three">Şimdi Kirala</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-12">
                        <div class="car-filter-empty" id="carFilterEmptyState">
                            Seçtiğiniz filtrelere uygun araç bulunamadı.
                        </div>
                    </div>
                </div>
                <div class="car-pagination-wrap">
                    <div class="car-pagination" id="carListPagination"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        function initCarListFilters(forceReinit) {
            if (!window.jQuery) {
                window.setTimeout(function () { initCarListFilters(forceReinit); }, 120);
                return;
            }

            var $ = window.jQuery;

            var alreadyBound = window.__carListFiltersBound === true;

            if (alreadyBound && !forceReinit) {
                return;
            }

            var minPrice = @minPrice;
            var maxPrice = @maxPrice;
            var currentMin = minPrice;
            var currentMax = maxPrice;
            var slider = $('#slider-range');
            var amount = $('#amount');
            var searchInput = $('#carSearchInput');
            var categoryFilter = $('#categoryFilter');
            var brandFilter = $('#brandFilter');
            var fuelFilter = $('#fuelFilter');
            var transmissionFilter = $('#transmissionFilter');
            var capacityFilters = $('.capacity-filter');
            var emptyState = $('#carFilterEmptyState');
            var pagination = $('#carListPagination');
            var itemsPerPage = 6;
            var currentPage = 1;

            function updateAmount(min, max) {
                amount.val(min + ' ₺ - ' + max + ' ₺');
            }

            function isSeatMatch(seatCount) {
                var checkedRanges = capacityFilters.filter(':checked');

                if (!checkedRanges.length) {
                    return true;
                }

                var matched = false;

                checkedRanges.each(function () {
                    var min = parseInt($(this).data('min'), 10);
                    var max = parseInt($(this).data('max'), 10);

                    if (seatCount >= min && seatCount <= max) {
                        matched = true;
                        return false;
                    }
                });

                return matched;
            }

            function renderPagination(totalItems, totalPages) {
                pagination.empty();

                if (totalItems <= itemsPerPage || totalPages <= 1) {
                    pagination.removeClass('is-visible');
                    return;
                }

                var prevButton = $('<button/>', {
                    type: 'button',
                    class: 'car-pagination-btn',
                    text: 'Önceki',
                    disabled: currentPage === 1
                }).on('click', function () {
                    if (currentPage > 1) {
                        currentPage--;
                        applyFilters(false);
                    }
                });

                pagination.append(prevButton);

                for (var page = 1; page <= totalPages; page++) {
                    (function (pageNumber) {
                        var numberButton = $('<button/>', {
                            type: 'button',
                            class: 'car-pagination-number' + (pageNumber === currentPage ? ' is-active' : ''),
                            text: pageNumber
                        }).on('click', function () {
                            currentPage = pageNumber;
                            applyFilters(false);
                        });

                        pagination.append(numberButton);
                    })(page);
                }

                var nextButton = $('<button/>', {
                    type: 'button',
                    class: 'car-pagination-btn',
                    text: 'Sonraki',
                    disabled: currentPage === totalPages
                }).on('click', function () {
                    if (currentPage < totalPages) {
                        currentPage++;
                        applyFilters(false);
                    }
                });

                pagination.append(nextButton);
                pagination.addClass('is-visible');
            }

            function applyFilters(resetPage) {
                var searchTerm = (searchInput.val() || '').toString().trim().toLowerCase();
                var selectedCategory = (categoryFilter.val() || '').toString();
                var selectedBrand = (brandFilter.val() || '').toString();
                var selectedFuel = (fuelFilter.val() || '').toString();
                var selectedTransmission = (transmissionFilter.val() || '').toString();
                var filteredCards = $();

                if (resetPage !== false) {
                    currentPage = 1;
                }

                $('.car-price-item').each(function () {
                    var card = $(this);
                    var price = parseFloat(card.data('price'));
                    var brand = (card.data('brand') || '').toString();
                    var category = (card.data('category') || '').toString();
                    var fuel = (card.data('fuel') || '').toString();
                    var transmission = (card.data('transmission') || '').toString();
                    var searchValue = (card.data('search') || '').toString();
                    var seatCount = parseInt(card.data('seat'), 10) || 0;

                    var matches =
                        price >= currentMin &&
                        price <= currentMax &&
                        (!searchTerm || searchValue.indexOf(searchTerm) !== -1) &&
                        (!selectedCategory || category === selectedCategory) &&
                        (!selectedBrand || brand === selectedBrand) &&
                        (!selectedFuel || fuel === selectedFuel) &&
                        (!selectedTransmission || transmission === selectedTransmission) &&
                        isSeatMatch(seatCount);

                    if (matches) {
                        filteredCards = filteredCards.add(card);
                    }

                    card.hide();
                });

                var visibleCount = filteredCards.length;
                var totalPages = Math.max(1, Math.ceil(visibleCount / itemsPerPage));

                if (currentPage > totalPages) {
                    currentPage = totalPages;
                }

                if (visibleCount > 0) {
                    var startIndex = (currentPage - 1) * itemsPerPage;
                    var endIndex = startIndex + itemsPerPage;
                    filteredCards.slice(startIndex, endIndex).show();
                }

                emptyState.toggle(visibleCount === 0);
                renderPagination(visibleCount, totalPages);
            }

            if (slider.length && $.fn.slider) {
                if (slider.hasClass('ui-slider')) {
                    slider.slider('destroy');
                }

                slider.slider({
                    range: true,
                    min: minPrice,
                    max: maxPrice,
                    values: [minPrice, maxPrice],
                    slide: function (event, ui) {
                        currentMin = ui.values[0];
                        currentMax = ui.values[1];
                        updateAmount(currentMin, currentMax);
                        applyFilters(true);
                    }
                });
            }

            updateAmount(minPrice, maxPrice);

            if (!alreadyBound) {
                $('#applyPriceFilterBtn').on('click.carListFilters', function () {
                    if (slider.length && slider.hasClass('ui-slider')) {
                        var values = slider.slider('values');
                        currentMin = values[0];
                        currentMax = values[1];
                    }

                    applyFilters(true);
                });

                $('#clearPriceFilterBtn').on('click.carListFilters', function () {
                    currentMin = minPrice;
                    currentMax = maxPrice;

                    if (slider.length && slider.hasClass('ui-slider')) {
                        slider.slider('values', [minPrice, maxPrice]);
                    }

                    updateAmount(minPrice, maxPrice);
                    searchInput.val('');
                    categoryFilter.val('');
                    brandFilter.val('');
                    fuelFilter.val('');
                    transmissionFilter.val('');
                    capacityFilters.prop('checked', false);
                    applyFilters(true);
                });

                $('#carSearchButton').on('click.carListFilters', function () { applyFilters(true); });
                searchInput.on('input.carListFilters', function () { applyFilters(true); });

                $(document).on('change.carListFilters', '#categoryFilter, #brandFilter, #fuelFilter, #transmissionFilter', function () {
                    applyFilters(true);
                });

                $(document).on('change.carListFilters', '.capacity-filter', function () {
                    applyFilters(true);
                });

                window.__carListFiltersBound = true;
            }

            applyFilters(true);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function () { initCarListFilters(false); });
        } else {
            initCarListFilters(false);
        }

        window.addEventListener('load', function () { initCarListFilters(true); });
    })();
</script>
