
@model CreateCategoryDto
@{
    ViewData["Title"] = "CreateCategory";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<main id="content">

    <!-- ============================================================
         PAGE HEADER
    ============================================================ -->
    <div class="page-header">
        <div>
            <div class="page-title">Kategori Oluştur</div>
            <div class="page-subtitle">Araç filonuz için yeni bir kategori tanımlayın.</div>
        </div>
        <a asp-area="Admin" asp-controller="Category" asp-action="CategoryList" class="btn-outline">
            <i class="bi bi-arrow-left"></i> Kategorilere Dön
        </a>
    </div>

    <!-- ============================================================
         STATS ROW
    ============================================================ -->
    <div class="row g-3 stats-row" id="statsRow">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="bi bi-tags"></i></div>
                <div>
                    <div class="stat-value" id="statTotal">0</div>
                    <div class="stat-label">Toplam Kategori</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-car-front"></i></div>
                <div>
                    <div class="stat-value" id="statCars">0</div>
                    <div class="stat-label">Toplam Araç</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
                <div>
                    <div class="stat-value" id="statActive">0</div>
                    <div class="stat-label">Aktif Kategori</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-icon red"><i class="bi bi-exclamation-circle"></i></div>
                <div>
                    <div class="stat-value" id="statEmpty">0</div>
                    <div class="stat-label">Boş Kategori</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================================================
         MAIN LAYOUT: FORM + PREVIEW
    ============================================================ -->
    <div class="row g-4">

        <!-- ── FORM CARD ── -->
        <div class="col-lg-7">
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon"><i class="bi bi-plus-lg"></i></div>
                    <div>
                        <div class="form-card-title">Yeni Kategori</div>
                        <div class="form-card-sub">Aşağıdaki alanları doldurun</div>
                    </div>
                </div>

                <form id="categoryForm"  method="post" onsubmit="handleSubmit(event)">
                    @Html.AntiForgeryToken()

                    <!-- Category Name -->
                    <div class="field-group">
                        <label class="field-label" for="CategoryName">
                            Kategori Adı
                            <span class="field-required">*</span>
                        </label>
                        <div class="field-input-wrap" id="nameWrap">
                            <i class="bi bi-tag field-icon"></i>
                            <input type="text"
                                   id="CategoryName"
                                   name="CategoryName"
                                   class="field-input"
                                   placeholder="ör. Sedan, SUV, Elektrik..."
                                   maxlength="60"
                                   autocomplete="off"
                                   oninput="syncPreview(this.value); validateName(this.value);"
                                   required />
                            <span class="char-count" id="charCount">0 / 60</span>
                        </div>
                        <div class="field-hint" id="nameHint">Kategori adı 2 ile 60 karakter arasında olmalıdır.</div>
                        <div class="field-error" id="nameError" style="display:none;"></div>
                    </div>

                    <!-- Icon Picker -->
                    <div class="field-group">
                        <label class="field-label">İkon Seç</label>
                        <div class="icon-grid" id="iconGrid">
                            <!-- populated by JS -->
                        </div>
                        <input type="hidden" name="CategoryIcon" id="CategoryIcon" value="bi-car-front" />
                    </div>

                    <!-- Color Picker -->
                    <div class="field-group">
                        <label class="field-label">Renk Etiketi</label>
                        <div class="color-swatches" id="colorSwatches">
                            <!-- populated by JS -->
                        </div>
                        <input type="hidden" name="CategoryColor" id="CategoryColor" value="yellow" />
                    </div>

                    <!-- Description (optional) -->
                    <div class="field-group">
                        <label class="field-label" for="CategoryDesc">Açıklama <span style="color:var(--text-muted);font-weight:400;">(isteğe bağlı)</span></label>
                        <div class="field-input-wrap">
                            <textarea id="CategoryDesc"
                                      name="CategoryDescription"
                                      class="field-input field-textarea"
                                      placeholder="Kategori hakkında kısa bir açıklama..."
                                      rows="3"
                                      maxlength="200"></textarea>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="form-actions">
                        <button type="button" class="btn-outline" onclick="resetForm()">
                            <i class="bi bi-arrow-counterclockwise"></i> Sıfırla
                        </button>
                        <button type="submit" class="btn-accent" id="submitBtn">
                            <i class="bi bi-check-lg"></i> Kategoriyi Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ── RIGHT COLUMN: PREVIEW + EXISTING ── -->
        <div class="col-lg-5">

            <!-- Live Preview -->
            <div class="preview-card" id="previewCard">
                <div class="preview-label">
                    <i class="bi bi-eye"></i> Canlı Önizleme
                </div>
                <div class="preview-badge-wrap">
                    <div class="preview-badge" id="previewBadge">
                        <div class="preview-badge-icon stat-icon yellow" id="previewIcon">
                            <i class="bi bi-car-front" id="previewIconEl"></i>
                        </div>
                        <div>
                            <div class="preview-badge-name" id="previewName">Kategori Adı</div>
                            <div class="preview-badge-sub">0 araç</div>
                        </div>
                    </div>
                    <div class="preview-chip-wrap">
                        <span class="preview-chip" id="previewChip">Kategori Adı</span>
                    </div>
                </div>
            </div>

            <!-- Existing Categories -->
            <div class="existing-card">
                <div class="existing-header">
                    <span class="existing-title">Mevcut Kategoriler</span>
                    <span class="existing-count" id="existingCount">0</span>
                </div>
                <div class="existing-list" id="existingList">
                    <div class="existing-empty">
                        <i class="bi bi-tags" style="font-size:28px;color:var(--text-muted);opacity:.4;"></i>
                        <p>Henüz kategori yok.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

</main>

<!-- ============================================================
     PAGE-SPECIFIC STYLES
============================================================ -->
<style>
    /* ── FORM CARD ── */
    .form-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 28px;
        animation: fadeUp .35s ease both;
    }

    .form-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

    .form-card-icon {
        width: 44px;
        height: 44px;
        background: var(--accent-dim);
        color: var(--accent);
        border-radius: 12px;
        display: grid;
        place-items: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .form-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 17px;
        font-weight: 700;
    }

    .form-card-sub {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* ── FIELD ── */
    .field-group {
        margin-bottom: 22px;
    }

    .field-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-muted);
        display: block;
        margin-bottom: 7px;
        letter-spacing: .2px;
    }

    .field-required {
        color: var(--danger);
        margin-left: 3px;
    }

    .field-input-wrap {
        position: relative;
    }

    .field-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 15px;
        pointer-events: none;
        transition: color var(--transition);
    }

    .field-input {
        width: 100%;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        padding: 10px 80px 10px 38px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border var(--transition), box-shadow var(--transition);
    }

        .field-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

            .field-input:focus + .field-icon,
            .field-input-wrap:focus-within .field-icon {
                color: var(--accent);
            }

        .field-input.error {
            border-color: var(--danger) !important;
            box-shadow: 0 0 0 3px rgba(255,82,89,.15) !important;
        }

        .field-input.success {
            border-color: var(--success) !important;
        }

    .field-textarea {
        padding: 10px 14px !important;
        resize: vertical;
        min-height: 80px;
    }

    .char-count {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 11px;
        color: var(--text-muted);
        pointer-events: none;
    }

    .field-hint {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    .field-error {
        font-size: 11px;
        color: var(--danger);
        margin-top: 5px;
    }

    /* ── ICON GRID ── */
    .icon-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .icon-opt {
        width: 42px;
        height: 42px;
        background: var(--bg-dark3);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        display: grid;
        place-items: center;
        font-size: 18px;
        color: var(--text-muted);
        cursor: pointer;
        transition: all var(--transition);
    }

        .icon-opt:hover {
            border-color: rgba(255,255,255,.2);
            color: var(--text);
        }

        .icon-opt.active {
            border-color: var(--accent);
            background: var(--accent-dim);
            color: var(--accent);
        }

    /* ── COLOR SWATCHES ── */
    .color-swatches {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .color-swatch {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: transform var(--transition), border-color var(--transition);
        position: relative;
    }

        .color-swatch:hover {
            transform: scale(1.15);
        }

        .color-swatch.active {
            border-color: var(--text);
            transform: scale(1.15);
        }

            .color-swatch.active::after {
                content: '\F26E';
                font-family: 'bootstrap-icons';
                position: absolute;
                inset: 0;
                display: grid;
                place-items: center;
                font-size: 14px;
                color: #fff;
                text-shadow: 0 1px 3px rgba(0,0,0,.5);
            }

    /* ── FORM ACTIONS ── */
    .form-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    /* ── PREVIEW CARD ── */
    .preview-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 22px;
        margin-bottom: 20px;
        animation: fadeUp .4s .1s ease both;
    }

    .preview-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-muted);
        font-weight: 600;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .preview-badge-wrap {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .preview-badge {
        display: flex;
        align-items: center;
        gap: 14px;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 14px 16px;
        transition: all var(--transition);
    }

    .preview-badge-name {
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        transition: color var(--transition);
    }

    .preview-badge-sub {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .preview-chip-wrap {
        display: flex;
        gap: 8px;
    }

    .preview-chip {
        display: inline-flex;
        align-items: center;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 12px;
        color: var(--text-muted);
        transition: all var(--transition);
    }

    /* ── EXISTING CATEGORIES ── */
    .existing-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        animation: fadeUp .45s .15s ease both;
    }

    .existing-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
    }

    .existing-title {
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
    }

    .existing-count {
        background: var(--accent-dim);
        color: var(--accent);
        font-size: 11px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 6px;
    }

    .existing-list {
        padding: 8px;
        max-height: 340px;
        overflow-y: auto;
    }

    .existing-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 12px;
        border-radius: 10px;
        cursor: default;
        transition: background var(--transition);
        animation: fadeUp .3s ease both;
    }

        .existing-item:hover {
            background: var(--bg-dark3);
        }

    .existing-item-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .existing-item-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: grid;
        place-items: center;
        font-size: 15px;
        flex-shrink: 0;
    }

    .existing-item-name {
        font-size: 13px;
        font-weight: 600;
    }

    .existing-item-cars {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 1px;
    }

    .existing-item-del {
        width: 28px;
        height: 28px;
        border: none;
        background: transparent;
        color: var(--text-muted);
        border-radius: 7px;
        display: grid;
        place-items: center;
        cursor: pointer;
        font-size: 13px;
        transition: background var(--transition), color var(--transition);
        opacity: 0;
        flex-shrink: 0;
    }

    .existing-item:hover .existing-item-del {
        opacity: 1;
    }

    .existing-item-del:hover {
        background: rgba(255,82,89,.12);
        color: var(--danger);
    }

    .existing-empty {
        text-align: center;
        padding: 32px 20px;
        color: var(--text-muted);
        font-size: 13px;
    }

        .existing-empty p {
            margin-top: 10px;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    <script>
        /* ============================================================
           CONFIG
        ============================================================ */
        const ICONS = [
          'bi-car-front','bi-truck','bi-bicycle','bi-ev-front','bi-speedometer2',
          'bi-fuel-pump','bi-bus-front','bi-taxi-front','bi-rocket','bi-lightning-charge',
          'bi-star','bi-shield-check','bi-gem','bi-trophy','bi-fire'
        ];

        const COLORS = [
          { key: 'yellow',  hex: '#e8ff47', dim: 'rgba(232,255,71,.15)'  },
          { key: 'blue',    hex: '#4f8dff', dim: 'rgba(79,141,255,.15)'  },
          { key: 'green',   hex: '#30e0a1', dim: 'rgba(48,224,161,.15)'  },
          { key: 'red',     hex: '#ff5259', dim: 'rgba(255,82,89,.15)'   },
          { key: 'purple',  hex: '#a855f7', dim: 'rgba(168,85,247,.15)'  },
          { key: 'orange',  hex: '#ffb547', dim: 'rgba(255,181,71,.15)'  },
          { key: 'cyan',    hex: '#22d3ee', dim: 'rgba(34,211,238,.15)'  },
          { key: 'pink',    hex: '#f472b6', dim: 'rgba(244,114,182,.15)' },
        ];

        /* Local category store (simulates server-side list) */
        let categories = [];
        let selectedIcon  = 'bi-car-front';
        let selectedColor = COLORS[0];

        /* ============================================================
           INIT
        ============================================================ */
        document.addEventListener('DOMContentLoaded', () => {
          buildIconGrid();
          buildColorSwatches();
          updateStats();
        });

        /* ============================================================
           ICON GRID
        ============================================================ */
        function buildIconGrid() {
          const grid = document.getElementById('iconGrid');
          grid.innerHTML = ICONS.map(ic => `
            <div class="icon-opt ${ic === selectedIcon ? 'active' : ''}"
                 title="${ic}"
                 onclick="selectIcon('${ic}', this)">
              <i class="bi ${ic}"></i>
            </div>
          `).join('');
        }

        function selectIcon(ic, el) {
          document.querySelectorAll('.icon-opt').forEach(e => e.classList.remove('active'));
          el.classList.add('active');
          selectedIcon = ic;
          document.getElementById('CategoryIcon').value = ic;
          // update preview
          document.getElementById('previewIconEl').className = `bi ${ic}`;
        }

        /* ============================================================
           COLOR SWATCHES
        ============================================================ */
        function buildColorSwatches() {
          const wrap = document.getElementById('colorSwatches');
          wrap.innerHTML = COLORS.map((c, i) => `
            <div class="color-swatch ${i === 0 ? 'active' : ''}"
                 style="background:${c.hex};"
                 title="${c.key}"
                 onclick="selectColor('${c.key}', this)">
            </div>
          `).join('');
        }

        function selectColor(key, el) {
          document.querySelectorAll('.color-swatch').forEach(e => e.classList.remove('active'));
          el.classList.add('active');
          selectedColor = COLORS.find(c => c.key === key);
          document.getElementById('CategoryColor').value = key;
          applyPreviewColor();
        }

        function applyPreviewColor() {
          const iconEl = document.getElementById('previewIcon');
          iconEl.style.background = selectedColor.dim;
          iconEl.style.color      = selectedColor.hex;
        }

        /* ============================================================
           LIVE PREVIEW SYNC
        ============================================================ */
        function syncPreview(val) {
          const name = val.trim() || 'Kategori Adı';
          document.getElementById('previewName').textContent  = name;
          document.getElementById('previewChip').textContent  = name;

          // char counter
          document.getElementById('charCount').textContent = `${val.length} / 60`;
          applyPreviewColor();
        }

        /* ============================================================
           VALIDATION
        ============================================================ */
        function validateName(val) {
          const input   = document.getElementById('CategoryName');
          const errEl   = document.getElementById('nameError');
          const hintEl  = document.getElementById('nameHint');
          const trimmed = val.trim();

          if (trimmed.length === 0) {
            setFieldState(input, errEl, hintEl, null);
            return false;
          }

          if (trimmed.length < 2) {
            setFieldState(input, errEl, hintEl, 'Kategori adı en az 2 karakter olmalıdır.', 'error');
            return false;
          }

          const duplicate = categories.some(c => c.name.toLowerCase() === trimmed.toLowerCase());
          if (duplicate) {
            setFieldState(input, errEl, hintEl, 'Bu isimde bir kategori zaten mevcut.', 'error');
            return false;
          }

          setFieldState(input, errEl, hintEl, null, 'success');
          return true;
        }

        function setFieldState(input, errEl, hintEl, msg, state) {
          input.classList.remove('error', 'success');
          errEl.style.display = 'none';
          if (state === 'error') {
            input.classList.add('error');
            errEl.textContent  = msg;
            errEl.style.display = 'block';
          } else if (state === 'success') {
            input.classList.add('success');
          }
        }

        /* ============================================================
           FORM SUBMIT (client-side demo + server submit)
        ============================================================ */
        function handleSubmit(e) {
          const nameVal = document.getElementById('CategoryName').value;
          if (!validateName(nameVal)) {
            e.preventDefault();
            return;
          }
        }

        /* ============================================================
           RESET FORM
        ============================================================ */
        function resetForm() {
          document.getElementById('CategoryName').value = '';
          document.getElementById('CategoryDesc').value  = '';
          document.getElementById('charCount').textContent = '0 / 60';
          syncPreview('');
          const input = document.getElementById('CategoryName');
          input.classList.remove('error', 'success');
          document.getElementById('nameError').style.display = 'none';
          // Reset selections
          selectedIcon  = 'bi-car-front';
          selectedColor = COLORS[0];
          buildIconGrid();
          buildColorSwatches();
          applyPreviewColor();
          document.getElementById('previewIconEl').className = 'bi bi-car-front';
        }

        /* ============================================================
           EXISTING LIST
        ============================================================ */
        function addToExistingList(cat) {
          categories.push(cat);
          renderExistingList();
          updateStats();
        }

        function renderExistingList() {
          const list = document.getElementById('existingList');
          document.getElementById('existingCount').textContent = categories.length;

          if (!categories.length) {
            list.innerHTML = `
              <div class="existing-empty">
                <i class="bi bi-tags" style="font-size:28px;color:var(--text-muted);opacity:.4;"></i>
                <p>Henüz kategori yok.</p>
              </div>`;
            return;
          }

          list.innerHTML = categories.map(c => `
            <div class="existing-item" id="ecat-${c.id}">
              <div class="existing-item-left">
                <div class="existing-item-icon" style="background:${c.color.dim};color:${c.color.hex};">
                  <i class="bi ${c.icon}"></i>
                </div>
                <div>
                  <div class="existing-item-name">${escHtml(c.name)}</div>
                  <div class="existing-item-cars">${c.cars} araç</div>
                </div>
              </div>
              <button class="existing-item-del" onclick="deleteCategory(${c.id})" title="Sil">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          `).join('');
        }

        function deleteCategory(id) {
          const el = document.getElementById('ecat-' + id);
          if (el) {
            el.style.transition = 'opacity .25s, transform .25s';
            el.style.opacity = '0';
            el.style.transform = 'translateX(10px)';
            setTimeout(() => {
              const idx = categories.findIndex(c => c.id === id);
              if (idx > -1) categories.splice(idx, 1);
              renderExistingList();
              updateStats();
              showToast('Kategori silindi.', 'danger');
            }, 250);
          }
        }

        /* ============================================================
           STATS
        ============================================================ */
        function updateStats() {
          document.getElementById('statTotal').textContent  = categories.length;
          document.getElementById('statCars').textContent   = categories.reduce((s, c) => s + c.cars, 0);
          document.getElementById('statActive').textContent  = categories.filter(c => c.cars > 0).length;
          document.getElementById('statEmpty').textContent   = categories.filter(c => c.cars === 0).length;
        }

        /* ============================================================
           HELPERS
        ============================================================ */
        function escHtml(str) {
          return str.replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
        }
    </script>
}


